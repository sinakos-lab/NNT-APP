{
  "version": 2,
  "builds": [
    {
      "src": "neatntidy/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "neatntidy/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/neatntidy/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/neatntidy/public/$1"
    }
  ]
}